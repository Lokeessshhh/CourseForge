# ─────────────────────────────────────────────────────────
# LearnAI Django Backend — Environment Variables
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-django-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_LOG_LEVEL=INFO

# ── Database (PostgreSQL + pgvector) ─────────────────────
DB_NAME=learnai
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk Authentication ──────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── vLLM (LLM Backend) ────────────────────────────────────
# vLLM server base URL
VLLM_BASE_URL=http://localhost:8000
# vLLM API key (use "none" if no auth required)
VLLM_API_KEY=none
# vLLM model name
VLLM_MODEL=qwen-coder
# Maximum tokens for generation
VLLM_MAX_TOKENS=3000
# Stream timeout in seconds
VLLM_STREAM_TIMEOUT=120

# ── Embedding Model ───────────────────────────────────────
EMBEDDING_MODEL_PRIMARY=Qwen/Qwen3-Embedding
EMBEDDING_MODEL_FALLBACK=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── CORS (additional production origins) ─────────────────
# Comma-separated list of extra allowed origins beyond localhost:3000
CORS_EXTRA_ORIGINS=https://your-production-domain.com

# ── Rate Limiting (Production) ────────────────────────────
# Enable/disable global rate limiting
RATE_LIMIT_ENABLED=True
# Max requests per hour per IP
RATE_LIMIT_REQUESTS_PER_HOUR=1000
# Block duration in seconds when limit exceeded
RATE_LIMIT_BLOCK_DURATION=3600

# ── Auth Rate Limiting ────────────────────────────────────
# Enable/disable auth-specific rate limiting
AUTH_RATE_LIMIT_ENABLED=True
# Max failed auth attempts per minute per IP
AUTH_RATE_LIMIT_MAX_FAILURES=10
# Window in seconds for counting failures
AUTH_RATE_LIMIT_WINDOW=60
# Block duration in seconds after max failures
AUTH_RATE_LIMIT_BLOCK_DURATION=300

# ── Production Security ───────────────────────────────────
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# ── Email (Production) ────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# ── External APIs ────────────────────────────────────────
TAVILY_API_KEY=tvly_xxxxxxxxxxxxxxxxxxxx
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-judge0-api-key
